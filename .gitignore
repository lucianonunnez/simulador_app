# ============================================================================
# Secrets y configuración sensible — NUNCA versionar
# ============================================================================
.streamlit/secrets.toml
secrets.toml
*.secret
.env
.env.*
!.env.example

# ============================================================================
# Datos de negocio (información sensible — no debe salir del entorno seguro)
# ============================================================================
data/
*.xlsx
*.xls
*.csv
!docs/**/*.csv

# Base DuckDB local (datos médicos -> nunca versionar)
*.duckdb
*.duckdb.wal

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
ENV/
# .python-version — tracked for Streamlit Cloud uv Python version selection

# ============================================================================
# Testing / tooling
# ============================================================================
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
coverage.xml

# ============================================================================
# Logs
# ============================================================================
logs/
*.log

# ============================================================================
# Editores / SO
# ============================================================================
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ============================================================================
# Artefactos de notebooks (entrenamiento se hace fuera del repo)
