# ============================================================================
# Plantilla de secrets.toml — COPIAR a .streamlit/secrets.toml y completar.
# El archivo real (.streamlit/secrets.toml) es local y está gitignored:
# contiene credenciales reales -> NUNCA se versiona ni se comparte.
#
# Para Streamlit Community Cloud: pegá cada key en el panel de Secrets del
# dashboard (Settings → Secrets).
# ============================================================================

# Clave para firmar la cookie de sesión. Generar una aleatoria y fuerte:
#     python scripts/gen_credentials.py --cookie-key
cookie_key = "REEMPLAZAR_POR_UN_VALOR_ALEATORIO_DE_64_HEX"
cookie_name = "simulador_cm_auth"
# Días hasta que caduca la sesión (1 = recomendado por seguridad).
cookie_expiry_days = 1

# ----------------------------------------------------------------------------
# Conexión a Supabase (proyecto gestor-clientes, schema simulador).
#
# Obtenerla desde: Supabase Dashboard → proyecto gestor-clientes →
# Settings → Database → Connection string → URI
#
# Para el script CLI de ingesta local, también podés exportar esta URL:
#     export DATABASE_URL="postgresql://..."
#     python scripts/ingest.py
# ----------------------------------------------------------------------------
supabase_db_url = "postgresql://postgres:[YOUR-PASSWORD]@db.rjpvmpjhuyhuhsuilnsg.supabase.co:5432/postgres"

# Para Streamlit Community Cloud se recomienda el pooler (más conexiones):
# supabase_db_url = "postgresql://postgres.[REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres"

# ----------------------------------------------------------------------------
# Usuarios. Un bloque por persona. El password va HASHEADO con bcrypt
# (lo genera scripts/gen_credentials.py). Nunca poner el password en texto plano.
# ----------------------------------------------------------------------------
[credentials.usernames.luciano]
name = "Luciano Núñez"
email = "luciano@ejemplo.com"
password = "$2b$12$REEMPLAZAR_POR_EL_HASH_BCRYPT_GENERADO"

[credentials.usernames.leo]
name = "Leo"
email = ""
password = "$2b$12$REEMPLAZAR_POR_EL_HASH_BCRYPT_GENERADO"

[credentials.usernames.lucas]
name = "Lucas"
email = ""
password = "$2b$12$REEMPLAZAR_POR_EL_HASH_BCRYPT_GENERADO"
