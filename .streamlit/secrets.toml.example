# ============================================================================
# PLANTILLA DE SECRETS — copiá este archivo a `.streamlit/secrets.toml`
# y completá los valores reales. NUNCA commitees `secrets.toml`.
# ============================================================================
#
# En despliegue (Hugging Face Spaces / contenedor) cargá estos valores como
# "Repository secrets" o variables del entorno, no como archivo en el repo.
#
# Para generar el hash de una contraseña:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'TU_PASSWORD', bcrypt.gensalt()).decode())"
#
# Para generar una cookie_key aleatoria:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# ── Sesión / cookie de autenticación ────────────────────────────────────────
cookie_key = "REEMPLAZAR_POR_CLAVE_ALEATORIA"
cookie_name = "simulador_cm_auth"
cookie_expiry_days = 7

# ── Usuarios ─────────────────────────────────────────────────────────────────
# El password es un hash bcrypt, nunca texto plano.
[credentials.usernames.admin]
name = "Nombre Apellido"
email = "usuario@ejemplo.com"
password = "$2b$12$REEMPLAZAR_POR_HASH_BCRYPT"
role = "admin"   # "admin" | "user"

# [credentials.usernames.otro_usuario]
# name = "Otro Usuario"
# email = "otro@ejemplo.com"
# password = "$2b$12$..."
# role = "user"

# ============================================================================
# ORIGEN DE DATOS (OneDrive / SharePoint)
# ============================================================================
# Links de compartición con permiso "cualquiera con el link" (o el alcance
# mínimo que la política de datos permita). Dejá vacío para usar carga manual.
onedrive_consumo_url = ""
onedrive_valores_url = ""
