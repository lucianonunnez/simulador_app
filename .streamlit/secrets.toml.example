# ============================================================================
# Plantilla de secrets.toml — COPIAR a .streamlit/secrets.toml y completar.
# El archivo real (.streamlit/secrets.toml) es local y está gitignored:
# contiene credenciales reales -> NUNCA se versiona ni se comparte.
#
# Para Streamlit Community Cloud: pegá cada key en el panel de Secrets del
# dashboard (Settings → Secrets).
# ============================================================================

# Clave para firmar la cookie de sesión. Generar una aleatoria y fuerte:
#     python scripts/gen_credentials.py --cookie-key
cookie_key = "REEMPLAZAR_POR_UN_VALOR_ALEATORIO_DE_64_HEX"
cookie_name = "simulador_cm_auth"
# Días hasta que caduca la sesión (1 = recomendado por seguridad).
cookie_expiry_days = 1

# ----------------------------------------------------------------------------
# Conexión a Supabase (proyecto gestor-clientes, schema simulador).
#
# ⚠️ IMPORTANTE — Streamlit Community Cloud es SOLO IPv4, y la conexión DIRECTA
# de Supabase (db.<ref>.supabase.co) es SOLO IPv6: desde la nube NO conecta
# (timeout silencioso). Usá SIEMPRE el **Session Pooler** (IPv4) para el deploy.
#
# Copiala del dashboard: proyecto gestor-clientes → botón "Connect" →
# "Session pooler". Tiene esta forma:
supabase_db_url = "postgresql://postgres.rjpvmpjhuyhuhsuilnsg:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# Usuarios y roles.
#
# Roles disponibles:
#   admin   — puede cargar datos + todos los módulos
#   manager — todos los módulos (sin carga de datos)
#   viewer  — solo Módulo 1
#
# El password va HASHEADO con bcrypt. Para generarlo:
#     python scripts/gen_credentials.py
# ----------------------------------------------------------------------------

# ── Admin ────────────────────────────────────────────────────────────────────
[credentials.usernames.luciano]
name = "Luciano Núñez"
email = "lucianonunnez@gmail.com"
password = "$2b$12$REEMPLAZAR_POR_EL_HASH_BCRYPT_GENERADO"
role = "admin"

# ── Managers (acceso completo, sin carga de datos) ───────────────────────────
[credentials.usernames.leo]
name = "Leo"
email = ""
password = "$2b$12$REEMPLAZAR_POR_EL_HASH_BCRYPT_GENERADO"
role = "manager"

[credentials.usernames.lucas]
name = "Lucas"
email = ""
password = "$2b$12$REEMPLAZAR_POR_EL_HASH_BCRYPT_GENERADO"
role = "manager"

[credentials.usernames.gonzalo]
name = "Gonzalo"
email = ""
password = "$2b$12$REEMPLAZAR_POR_EL_HASH_BCRYPT_GENERADO"
role = "manager"

[credentials.usernames.catalina]
name = "Catalina"
email = ""
password = "$2b$12$REEMPLAZAR_POR_EL_HASH_BCRYPT_GENERADO"
role = "manager"

# ── Viewer (solo Módulo 1) ───────────────────────────────────────────────────
[credentials.usernames.ejecutivos]
name = "Ejecutivos"
email = ""
password = "$2b$12$REEMPLAZAR_POR_EL_HASH_BCRYPT_GENERADO"
role = "viewer"
